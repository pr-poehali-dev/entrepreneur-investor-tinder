{
  "tests": [
    {
      "name": "Send OTP email",
      "method": "POST",
      "path": "/",
      "body": {"action": "send", "contact": "test@example.com"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Send OTP phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "send", "contact": "+79991234567"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify wrong code",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify", "contact": "test@example.com", "code": "000000"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "POST me unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}
